    {
      "$schema": "urn:prism:schema:v1:spec",
      "data": {"values": [{"x": 1, "score": 10.5}, {"x": 2, "score": 22.0}]},
      "mark": "line",
      "encoding": {
        "x": {"field": "x",     "type": "quantitative"},
        "y": {"field": "score", "type": "quantitative"}
      }
    }
  ]
