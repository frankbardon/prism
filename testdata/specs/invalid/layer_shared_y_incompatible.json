{
  "$schema": "urn:prism:schema:v1:spec",
  "title": "Incompatible shared y-scale (P08 negative fixture)",
  "resolve": {"scale": {"y": "shared"}},
  "layer": [
    {
      "$schema": "urn:prism:schema:v1:spec",
      "data": {"values": [{"x": 1, "category": "alpha"}, {"x": 2, "category": "beta"}]},
      "mark": "point",
      "encoding": {
        "x": {"field": "x",        "type": "quantitative"},
        "y": {"field": "category", "type": "nominal"}
