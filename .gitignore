bin/
*.test
*.out
coverage.txt
coverage.out

# mdBook output — `make docs` builds into docs/book/, `make docs-clean` removes it.
docs/book/

# Gallery SceneDoc JSON — derived from *.prism.json by `make docs-scenes`.
# Regenerated on every `make docs`; live <prism-chart> needs them but they
# are not source of truth.
docs/src/gallery/**/*.scene.json

.DS_Store
.idea/

# VSCode: share workspace settings + recommended extensions, ignore
# per-user state (launch, tasks, history, etc.).
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# Cross-impl parity harness — npm dev deps installed locally per
# internal/devtools/cross-impl-runner/README.md. Never commit.
internal/devtools/cross-impl-runner/node_modules/
internal/devtools/cross-impl-runner/package-lock.json

# Per-run cross-impl artifacts. scene.json + go.svg are committed
# (the Go-side canonical inputs); js.svg + diff.txt are generated
# each test run.
testdata/cross_impl/**/js.svg
testdata/cross_impl/**/diff.txt
