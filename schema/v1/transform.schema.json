{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:prism:schema:v1:transform",
  "title": "Prism Transforms",
  "description": "Discriminated transform variants applied to a dataset.",
  "$defs": {
    "aggregate_op": {
      "type": "string",
      "description": "Friendly aggregate alias mapped to Pulse internals by the compiler.",
      "enum": [
        "count", "sum", "mean", "median", "min", "max", "stdev", "variance",
        "range", "skewness", "kurtosis", "null_count",
        "q1", "q3", "ci0", "ci1",
        "distinct", "mode",
        "wmean", "ratio", "lift", "share"
      ]
    },
    "transform_base": {
      "type": "object",
      "description": "Optional fields available on every transform variant.",
      "properties": {
        "data": {
          "type": "string",
          "description": "Alias of the input dataset for this transform.",
          "minLength": 1
        },
        "as": {
          "type": "string",
          "description": "Alias under which the transform output is registered.",
          "minLength": 1
        }
      }
    },
    "transform": {
      "oneOf": [
        {"$ref": "transform.schema.json#/$defs/filter_transform"},
        {"$ref": "transform.schema.json#/$defs/calculate_transform"},
        {"$ref": "transform.schema.json#/$defs/aggregate_transform"},
        {"$ref": "transform.schema.json#/$defs/bin_transform"},
        {"$ref": "transform.schema.json#/$defs/window_transform"},
        {"$ref": "transform.schema.json#/$defs/join_transform"},
        {"$ref": "transform.schema.json#/$defs/union_transform"},
        {"$ref": "transform.schema.json#/$defs/pivot_transform"},
        {"$ref": "transform.schema.json#/$defs/unpivot_transform"},
        {"$ref": "transform.schema.json#/$defs/sample_transform"},
        {"$ref": "transform.schema.json#/$defs/sort_transform"},
        {"$ref": "transform.schema.json#/$defs/limit_transform"},
        {"$ref": "transform.schema.json#/$defs/crosstab_transform"},
        {"$ref": "transform.schema.json#/$defs/regression_transform"}
      ],
      "description": "Single transform step; exactly one of the 14 variants identified by its discriminator key."
    },
    "filter_transform": {
      "type": "object",
      "description": "Row filter expressed as a Pulse expression predicate.",
      "additionalProperties": false,
      "required": ["filter"],
      "properties": {
        "filter": {"$ref": "shared.schema.json#/$defs/expression", "description": "Pulse expression evaluated per row; truthy rows pass."},
        "data":   {"type": "string", "minLength": 1, "description": "Optional input alias."},
        "as":     {"type": "string", "minLength": 1, "description": "Optional output alias."}
      }
    },
    "calculate_transform": {
      "type": "object",
      "description": "Compute a new column from a Pulse expression and bind it to a name.",
      "additionalProperties": false,
      "required": ["calculate", "as"],
      "properties": {
        "calculate": {"$ref": "shared.schema.json#/$defs/expression", "description": "Pulse expression producing the new column value."},
        "as":        {"type": "string", "minLength": 1, "description": "Name of the new column."},
        "data":      {"type": "string", "minLength": 1, "description": "Optional input alias."}
      }
    },
    "aggregate_transform": {
      "type": "object",
      "description": "Group-by aggregate; produces one row per groupby key combination.",
      "additionalProperties": false,
      "required": ["aggregate"],
      "properties": {
        "groupby": {
          "type": "array",
          "description": "Field names to group by; omit for global aggregation.",
          "items": {"$ref": "shared.schema.json#/$defs/field_ref"}
        },
        "aggregate": {
          "type": "array",
          "description": "List of aggregate operations to compute.",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["op", "as"],
            "properties": {
              "op":    {"$ref": "transform.schema.json#/$defs/aggregate_op", "description": "Aggregate operation."},
              "field": {"$ref": "shared.schema.json#/$defs/field_ref", "description": "Field to aggregate; omitted for count and similar ops."},
              "as":    {"type": "string", "minLength": 1, "description": "Output column name."}
            }
          }
        },
        "data": {"type": "string", "minLength": 1, "description": "Optional input alias."},
        "as":   {"type": "string", "minLength": 1, "description": "Optional output alias."}
      }
    },
    "bin_transform": {
      "type": "object",
      "description": "Bin a numeric field into buckets.",
      "additionalProperties": false,
      "required": ["bin", "field", "as"],
      "properties": {
        "bin": {
          "oneOf": [
            {"type": "boolean", "description": "True enables automatic binning."},
            {
              "type": "object",
              "additionalProperties": false,
              "description": "Manual bin parameters.",
              "properties": {
                "maxbins": {"type": "integer", "minimum": 1, "description": "Maximum number of bins."},
                "step":    {"type": "number", "exclusiveMinimum": 0, "description": "Fixed bin width."},
                "extent":  {
                  "type": "array",
                  "items": {"type": "number"},
                  "minItems": 2,
                  "maxItems": 2,
                  "description": "Lower/upper bound for the binning extent."
                }
              }
            }
          ],
          "description": "Bin configuration."
        },
        "field": {"$ref": "shared.schema.json#/$defs/field_ref", "description": "Field to bin."},
        "as":    {"type": "string", "minLength": 1, "description": "Output bin field name."},
        "data":  {"type": "string", "minLength": 1, "description": "Optional input alias."}
      }
    },
    "window_transform": {
      "type": "object",
      "description": "Windowed aggregate or rank within a partition.",
      "additionalProperties": false,
      "required": ["window"],
      "properties": {
        "window": {
          "type": "array",
          "description": "One or more window operations.",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["op", "as"],
            "properties": {
              "op":    {"type": "string", "description": "Window operation name.", "enum": ["row_number", "rank", "dense_rank", "lag", "lead", "first_value", "last_value", "sum", "mean", "min", "max", "count"]},
              "field": {"$ref": "shared.schema.json#/$defs/field_ref", "description": "Field for ops that take one."},
              "as":    {"type": "string", "minLength": 1, "description": "Output column name."},
              "param": {"type": "number", "description": "Numeric parameter (e.g. lag offset)."}
            }
          }
        },
        "partitionby": {
          "type": "array",
          "description": "Partition keys.",
          "items": {"$ref": "shared.schema.json#/$defs/field_ref"}
        },
        "sort": {
          "type": "array",
          "description": "Sort spec within the partition.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["field"],
            "properties": {
              "field": {"$ref": "shared.schema.json#/$defs/field_ref"},
              "order": {"type": "string", "enum": ["ascending", "descending"], "description": "Sort direction."}
            }
          }
        },
        "frame": {
          "type": "array",
          "items": {"type": ["integer", "null"]},
          "minItems": 2,
          "maxItems": 2,
          "description": "Window frame as [before, after] row offsets; null for unbounded."
        },
        "data": {"type": "string", "minLength": 1, "description": "Optional input alias."},
        "as":   {"type": "string", "minLength": 1, "description": "Optional output alias."}
      }
    },
    "join_transform": {
      "type": "object",
      "description": "Join two datasets on equality of key fields.",
      "additionalProperties": false,
      "required": ["join", "with", "on"],
      "properties": {
        "join": {"type": "string", "enum": ["inner", "left", "right", "outer", "anti", "semi"], "description": "Join kind."},
        "with": {"type": "string", "minLength": 1, "description": "Name of the right-hand dataset."},
        "on": {
          "oneOf": [
            {"$ref": "shared.schema.json#/$defs/field_ref"},
            {
              "type": "array",
              "items": {"$ref": "shared.schema.json#/$defs/field_ref"},
              "minItems": 1,
              "description": "List of key fields used for both sides."
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["left", "right"],
              "properties": {
                "left":  {"type": "array", "items": {"$ref": "shared.schema.json#/$defs/field_ref"}, "minItems": 1, "description": "Left-side key fields."},
                "right": {"type": "array", "items": {"$ref": "shared.schema.json#/$defs/field_ref"}, "minItems": 1, "description": "Right-side key fields."}
              },
              "description": "Explicit left/right key mapping."
            }
          ],
          "description": "Join keys."
        },
        "data": {"type": "string", "minLength": 1, "description": "Left-hand input alias."},
        "as":   {"type": "string", "minLength": 1, "description": "Output alias."}
      }
    },
    "union_transform": {
      "type": "object",
      "description": "Vertically concatenate datasets that share a schema.",
      "additionalProperties": false,
      "required": ["union"],
      "properties": {
        "union": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "minItems": 2,
          "description": "Names of datasets to union."
        },
        "data": {"type": "string", "minLength": 1, "description": "Optional first input alias (alternative to including it in union)."},
        "as":   {"type": "string", "minLength": 1, "description": "Optional output alias."}
      }
    },
    "pivot_transform": {
      "type": "object",
      "description": "Wide-form pivot: spread distinct values of a field across columns.",
      "additionalProperties": false,
      "required": ["pivot", "value"],
      "properties": {
        "pivot": {"$ref": "shared.schema.json#/$defs/field_ref", "description": "Field whose distinct values become new column names."},
        "value": {"$ref": "shared.schema.json#/$defs/field_ref", "description": "Field providing the cell values."},
        "groupby": {
          "type": "array",
          "items": {"$ref": "shared.schema.json#/$defs/field_ref"},
          "description": "Group keys preserved as row identifiers."
        },
        "op":   {"$ref": "transform.schema.json#/$defs/aggregate_op", "description": "Aggregate op used when multiple rows collapse into one cell."},
        "data": {"type": "string", "minLength": 1, "description": "Optional input alias."},
        "as":   {"type": "string", "minLength": 1, "description": "Optional output alias."}
      }
    },
    "unpivot_transform": {
      "type": "object",
      "description": "Long-form unpivot: stack wide columns into name/value pairs.",
      "additionalProperties": false,
      "required": ["unpivot"],
      "properties": {
        "unpivot": {
          "type": "array",
          "items": {"$ref": "shared.schema.json#/$defs/field_ref"},
          "minItems": 1,
          "description": "Columns to stack."
        },
        "as": {
          "type": "array",
          "items": {"type": "string"},
          "minItems": 2,
          "maxItems": 2,
          "description": "Output [name_col, value_col] pair."
        },
        "data": {"type": "string", "minLength": 1, "description": "Optional input alias."}
      }
    },
    "sample_transform": {
      "type": "object",
      "description": "Randomly subsample the dataset.",
      "additionalProperties": false,
      "required": ["sample"],
      "properties": {
        "sample": {"type": "integer", "minimum": 1, "description": "Maximum number of rows to keep."},
        "seed":   {"type": "integer", "description": "Optional PRNG seed for deterministic sampling."},
        "data":   {"type": "string", "minLength": 1, "description": "Optional input alias."},
        "as":     {"type": "string", "minLength": 1, "description": "Optional output alias."}
      }
    },
    "sort_transform": {
      "type": "object",
      "description": "Sort rows by one or more fields.",
      "additionalProperties": false,
      "required": ["sort"],
      "properties": {
        "sort": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["field"],
            "properties": {
              "field": {"$ref": "shared.schema.json#/$defs/field_ref"},
              "order": {"type": "string", "enum": ["ascending", "descending"], "description": "Sort direction."}
            }
          }
        },
        "data": {"type": "string", "minLength": 1, "description": "Optional input alias."},
        "as":   {"type": "string", "minLength": 1, "description": "Optional output alias."}
      }
    },
    "limit_transform": {
      "type": "object",
      "description": "Keep the first N rows after any prior transforms.",
      "additionalProperties": false,
      "required": ["limit"],
      "properties": {
        "limit":  {"type": "integer", "minimum": 1, "description": "Row cap."},
        "offset": {"type": "integer", "minimum": 0, "description": "Optional starting offset."},
        "data":   {"type": "string", "minLength": 1, "description": "Optional input alias."},
        "as":     {"type": "string", "minLength": 1, "description": "Optional output alias."}
      }
    },

    "crosstab_transform": {
      "type": "object",
      "description": "Cross-tabulation built by Pulse: rows x columns x cell aggregation, with optional margins and normalisation. Must be the first transform on the chain (it consumes the source cohort directly).",
      "additionalProperties": false,
      "required": ["crosstab"],
      "properties": {
        "crosstab": {
          "type": "object",
          "additionalProperties": false,
          "required": ["rows", "columns", "cell"],
          "properties": {
            "rows":    {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/crosstab_group"}, "description": "Row-axis groupers."},
            "columns": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/crosstab_group"}, "description": "Column-axis groupers."},
            "cell":    {"$ref": "#/$defs/crosstab_cell", "description": "Cell aggregation."},
            "margins": {"$ref": "#/$defs/crosstab_margins", "description": "Toggle emission of row / column / grand-total rows."},
            "normalize": {
              "type": "string",
              "enum": ["none", "row", "column", "total"],
              "description": "Cell normalisation mode. none (default), row (cells in each row sum to 1), column (cells in each column sum to 1), total (whole table sums to 1)."
            },
            "shape": {
              "type": "string",
              "enum": ["long", "matrix"],
              "description": "Response shape. long (default) returns one row per (row-key, column-key) cell. matrix returns Pulse's structured payload on Response.Crosstab — reserved for a future encoder."
            },
            "overlays": {
              "type": "array",
              "items": {"$ref": "#/$defs/crosstab_overlay"},
              "description": "Post-result overlay layers; each adds one F64 column aligned to the base cell, suitable for a color/opacity channel. Runs the crosstab in matrix shape internally."
            }
          }
        },
        "data": {"type": "string", "minLength": 1, "description": "Optional input alias (must resolve to a registered .pulse dataset)."},
        "as":   {"type": "string", "minLength": 1, "description": "Optional output alias."}
      }
    },

    "crosstab_group": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field"],
      "properties": {
        "field":  {"type": "string", "minLength": 1, "description": "Cohort field to group on."},
        "type":   {"type": "string", "enum": ["category", "date"], "description": "Grouper kind. category (default, GROUP_CATEGORY) or date (GROUP_DATE, calendar bucketing of a temporal field)."},
        "period": {"type": "string", "enum": ["year", "quarter", "month", "week", "day", "day_of_week"], "description": "Calendar component for a date grouper (default month). Ignored for category groupers."}
      }
    },

    "crosstab_overlay": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {"type": "string", "enum": ["share_of_row", "share_of_col", "index_vs_margin", "zscore_vs_margin"], "description": "Overlay kind. share_of_row/col emit cell / axis-margin; index_vs_margin emits cell / margin * 100; zscore_vs_margin emits the standardized (cell - margin)/sd. index_vs_margin and zscore_vs_margin require axis."},
        "axis": {"type": "string", "enum": ["row", "column"], "description": "Margin axis for index_vs_margin / zscore_vs_margin. Ignored for share_of_row/col."},
        "as":   {"type": "string", "minLength": 1, "description": "Output column name (defaults to the kind)."}
      }
    },

    "regression_transform": {
      "type": "object",
      "description": "OLS regression fit (Pulse ATTR_REG_FITTED): augments each source row with a fitted ŷ column, sorted by the first predictor for trend-line rendering. Must be the first transform on the chain (it fits the source cohort directly).",
      "additionalProperties": false,
      "required": ["regression"],
      "properties": {
        "regression": {
          "type": "object",
          "additionalProperties": false,
          "required": ["target", "predictors"],
          "properties": {
            "target":     {"type": "string", "minLength": 1, "description": "Dependent variable (y)."},
            "predictors": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "description": "Independent variables (x). Multiple predictors fit a multiple regression."},
            "as":         {"type": "string", "minLength": 1, "description": "Fitted-value output column name (defaults to fitted)."}
          }
        },
        "data": {"type": "string", "minLength": 1, "description": "Optional input alias (must resolve to a registered .pulse dataset)."},
        "as":   {"type": "string", "minLength": 1, "description": "Optional output alias."}
      }
    },

    "crosstab_cell": {
      "type": "object",
      "additionalProperties": false,
      "required": ["aggregate"],
      "properties": {
        "aggregate": {"$ref": "transform.schema.json#/$defs/aggregate_op", "description": "Per-cell aggregate (Pulse-backed alias)."},
        "field":     {"type": "string", "minLength": 1, "description": "Cohort field to aggregate. Omit for count."},
        "as":        {"type": "string", "minLength": 1, "description": "Output column name. Defaults to _value."}
      }
    },

    "crosstab_margins": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rows":    {"type": "boolean", "description": "Emit per-row totals as additional rows with _margin = \"rows\"."},
        "columns": {"type": "boolean", "description": "Emit per-column totals as additional rows with _margin = \"columns\"."},
        "grand":   {"type": "boolean", "description": "Emit the grand-total row with _margin = \"grand\"."}
      }
    }
  }
}
